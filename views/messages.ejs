<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Messages - TeleAdminPanel</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/sidebar') %>

    <div class="app-container">
        <header>
            <h1 class="page-title">✉️ System Messages & Broadcasts</h1>
            <p class="page-subtitle">View and compose direct notifications to bot subscribers.</p>
        </header>

        <div class="grid-container" style="align-items: start; grid-template-columns: 2fr 1fr;">
            <div>
                <h2 style="margin-bottom: 1.25rem; font-weight: 700;">Sent Messages History</h2>
                <div style="display: flex; flex-direction: column; gap: 1rem;">
                    <% if (messages && messages.length > 0) { %>
                        <% messages.forEach(message => { %>
                            <div class="card" style="padding: 1.25rem 1.5rem;">
                                <div class="flex-between" style="margin-bottom: 0.5rem;">
                                    <span class="badge badge-info"><%= message.sender %></span>
                                    <span style="font-size: 0.8rem; color: var(--text-secondary);">Sent via Broadcast</span>
                                </div>
                                <p style="font-size: 1rem; color: var(--text-primary); line-height: 1.6;"><%= message.content %></p>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="card" style="text-align: center; color: var(--text-secondary); padding: 2rem;">
                            No messages have been sent yet.
                        </div>
                    <% } %>
                </div>
            </div>

            <div>
                <h2 style="margin-bottom: 1.25rem; font-weight: 700;">Send New</h2>
                <div class="form-container" style="max-width: 100%; padding: 1.5rem;">
                    <form action="/messages/send" method="post">
                        <div class="form-group">
                            <label>Sender Identity</label>
                            <input type="text" name="sender" value="Admin" required>
                        </div>
                        <div class="form-group">
                            <label>Message Content</label>
                            <textarea name="content" rows="4" placeholder="Write message..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary" style="width: 100%;">Broadcast Message</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

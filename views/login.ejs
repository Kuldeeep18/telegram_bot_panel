<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - TeleAdminPanel</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="login-body">
    <div class="login-card">
        <div class="logo-container" style="justify-content: center; margin-bottom: 2rem;">
            <div class="logo-icon">T</div>
            <div class="logo-text" style="font-size: 1.5rem;">TeleAdminPanel</div>
        </div>

        <h2 style="text-align: center; margin-bottom: 1.5rem; font-weight: 700; color: var(--text-primary);">Administrator Login</h2>
        
        <form action="/users/login" method="post">
            <div class="form-group">
                <label>Username</label>
                <input type="text" name="username" placeholder="Enter admin username" required>
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="Enter admin password" required>
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1rem;">Sign In</button>
        </form>
    </div>
</body>
</html>

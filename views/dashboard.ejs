<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - TeleAdminPanel</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/sidebar') %>
    
    <div class="app-container">
        <header>
            <h1 class="page-title">📊 Dashboard</h1>
            <p class="page-subtitle">Welcome back, Administrator. Here's your bot's system overview.</p>
        </header>

        <div class="grid-container">
            <div class="card">
                <div class="card-badge badge-info">Active</div>
                <div class="card-title">Bot Status</div>
                <div class="card-value" style="color: var(--success); font-size: 1.5rem; margin-top: 0.5rem;">Online & Polling</div>
            </div>
            <div class="card">
                <div class="card-title">Total Users</div>
                <div class="card-value"><%= typeof totalUsers !== 'undefined' ? totalUsers : 0 %></div>
            </div>
            <div class="card">
                <div class="card-title">Monthly Revenue</div>
                <div class="card-value">$<%= typeof revenue !== 'undefined' ? revenue : 0 %></div>
            </div>
        </div>

        <h2 style="margin-bottom: 1.5rem; font-weight: 700;">System Controls & Quick Actions</h2>
        <div class="grid-container" style="grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));">
            <div class="card">
                <h3 style="margin-bottom: 1rem;">Broadcast Message</h3>
                <form action="/messages/send" method="post">
                    <div class="form-group">
                        <label>Sender Tag</label>
                        <input type="text" name="sender" value="Admin" required>
                    </div>
                    <div class="form-group">
                        <label>Content</label>
                        <textarea name="content" rows="3" placeholder="Type a message to broadcast..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Send Broadcast</button>
                </form>
            </div>

            <div class="card">
                <h3 style="margin-bottom: 1rem;">Add Subscription</h3>
                <form action="/subscriptions/create" method="post">
                    <div class="form-group">
                        <label>User Handle</label>
                        <input type="text" name="subscriptionDetails[user]" placeholder="@username" required>
                    </div>
                    <div class="form-group">
                        <label>Plan</label>
                        <select name="subscriptionDetails[plan]">
                            <option value="Premium Signal Service">Premium Signal Service</option>
                            <option value="Elite Auto-Trader">Elite Auto-Trader</option>
                            <option value="Basic Telegram Alerts">Basic Telegram Alerts</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Duration</label>
                        <input type="text" name="subscriptionDetails[endDate]" value="30 Days" required>
                    </div>
                    <button type="submit" class="btn btn-primary">Create Subscription</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>

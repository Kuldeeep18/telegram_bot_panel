<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Statistics - TeleAdminPanel</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/sidebar') %>

    <div class="app-container">
        <header>
            <h1 class="page-title">📈 Analytics & Metrics</h1>
            <p class="page-subtitle">Historical user growth, payment statistics, and bot conversion metrics.</p>
        </header>

        <div class="grid-container">
            <div class="card">
                <div class="card-title">Total Active Users</div>
                <div class="card-value" style="color: var(--primary);"><%= totalUsers %></div>
                <p style="font-size: 0.85rem; color: var(--success); margin-top: 0.5rem;">↑ 12% increase this month</p>
            </div>
            <div class="card">
                <div class="card-title">Successful Purchases</div>
                <div class="card-value" style="color: var(--success);"><%= totalPayments %></div>
                <p style="font-size: 0.85rem; color: var(--success); margin-top: 0.5rem;">↑ 8% conversion rate</p>
            </div>
            <div class="card">
                <div class="card-title">Conversion Rate</div>
                <div class="card-value" style="color: var(--accent);">30%</div>
                <p style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.5rem;">Industry average: 18%</p>
            </div>
        </div>

        <h2 style="margin-bottom: 1.5rem; font-weight: 700;">Monthly Conversion Funnel</h2>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Month</th>
                        <th>User Signup Growth</th>
                        <th>Completed Sales</th>
                        <th>Ratio</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>January</td>
                        <td>100 users</td>
                        <td>30 sales</td>
                        <td><span class="badge badge-info">30%</span></td>
                    </tr>
                    <tr>
                        <td>February</td>
                        <td>120 users</td>
                        <td>35 sales</td>
                        <td><span class="badge badge-info">29.1%</span></td>
                    </tr>
                    <tr>
                        <td>March</td>
                        <td>150 users</td>
                        <td>45 sales</td>
                        <td><span class="badge badge-info">30%</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
